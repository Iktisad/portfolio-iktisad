# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# No .env file is needed for production — these variables are only used
# by the admin dashboard, which is blocked on non-localhost environments.

# Local API server URL (used by the admin dashboard to read/write data.json)
# Run `npm run api` to start the API server on this port
VITE_API_URL=http://localhost:3005

# Set to TRUE in local development
VITE_ENV_DEV=TRUE
